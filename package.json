{
  "name": "tmack48",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "TMACK48 — official luxury artist universe. Cinematic promotional site for the TMACK48 YouTube brand.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build",
    "build:only": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc -b --noEmit",
    "postbuild:cf": "node scripts/patch-cfasync.mjs",
    "deploy": "npm run build && npm run postbuild:cf && wrangler pages deploy dist --project-name=tmack48 --branch=main --commit-dirty=true",
    "deploy:all": "npm run build && npm run postbuild:cf && node scripts/deploy-retry.mjs",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "sitemap": "node scripts/generate-sitemap.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "framer-motion": "^11.11.17",
    "gsap": "^3.12.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.27.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wrangler": "^3.87.0"
  }
}
